# Build context exclusions for the Dockerfile in this directory.
# Mirrors most of .gitignore but adds a few build-specific items.

.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.git/
.gitignore
.idea/
.vscode/
.DS_Store

# Large data files are mounted at runtime; do not bake into the image.
data/raw/*.parquet
data/processed/*.parquet
data/external/cache/
data/external/football_data/
data/external/prediction_markets/

# Build artefacts and results.
results/*.html
results/*.json
results/*.md

# Local-only files.
fifa-fantasy-project-sketch.md
docs/

# Re-include the pre-tournament snapshot so the optimizer can run out of
# the box on a fresh container without internet access.
!data/raw/players_2026-06-08.parquet
!data/raw/squads_2026-06-08.parquet
!data/raw/fixtures_2026-06-08.parquet
!data/processed/features_2026-06-08.parquet
!data/processed/predictions_2026-06-08.parquet

# Models are part of the image so the GBM backend works immediately.
# (Override .gitignore: include the trained text artefacts.)
!data/models/*.txt
