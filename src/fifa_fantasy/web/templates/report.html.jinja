<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{% if refresh_seconds and refresh_seconds > 0 %}<meta http-equiv="refresh" content="{{ refresh_seconds }}">{% endif %}
<title>WC2026 Prediction Desk{% if featured %} - {{ featured.stage_label }}{% endif %}</title>
<style>
  :root {
    --paper: #f3efe6;
    --panel: #faf7f0;
    --ink: #1b1712;
    --ink-soft: #6a6155;
    --line: #d8d0c0;
    --line-hard: #bdb3a0;
    --accent: #2f6b3f;
    --signal: #a8620a;
    --fresh: #2f6b3f;
    --warn: #a8620a;
    --stale: #9c2b2b;
    --pitch: #24462f;
    --pitch-line: rgba(255,255,255,0.16);
    --mono: ui-monospace, "SFMono-Regular", "JetBrains Mono", Menlo, Consolas, monospace;
    --sans: system-ui, -apple-system, "Segoe UI", Helvetica, Arial, sans-serif;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --paper: #14130f;
      --panel: #1c1a15;
      --ink: #e9e3d5;
      --ink-soft: #9a9384;
      --line: #302c24;
      --line-hard: #423d33;
      --accent: #6fb884;
      --signal: #e6a94a;
      --fresh: #6fb884;
      --warn: #e6a94a;
      --stale: #e07a6f;
      --pitch: #1a3322;
      --pitch-line: rgba(255,255,255,0.13);
    }
  }
  * { box-sizing: border-box; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    font-family: var(--sans); background: var(--paper); color: var(--ink);
    margin: 0; padding: 0; line-height: 1.45;
    font-feature-settings: "tnum" 1, "cv01" 1;
  }
  .wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px 64px; }
  .num { font-family: var(--mono); font-variant-numeric: tabular-nums; }

  /* Masthead */
  header.mast {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
    padding: 22px 0 12px; border-bottom: 2px solid var(--ink);
    margin-bottom: 4px;
  }
  .mast .brand { font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    font-size: 0.95rem; }
  .mast .brand small { display: block; font-weight: 500; letter-spacing: 0.28em;
    font-size: 0.62rem; color: var(--ink-soft); margin-top: 3px; }
  .mast .status { font-family: var(--mono); font-size: 0.72rem; text-align: right;
    color: var(--ink-soft); }
  .live { display: inline-flex; align-items: center; gap: 6px; color: var(--ink); }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--fresh);
    box-shadow: 0 0 0 0 var(--fresh); animation: pulse 2.4s infinite; }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(111,184,132,0.5); }
    70% { box-shadow: 0 0 0 6px rgba(111,184,132,0); }
    100% { box-shadow: 0 0 0 0 rgba(111,184,132,0); }
  }
  .subline { display: flex; gap: 14px; flex-wrap: wrap; align-items: baseline;
    font-size: 0.78rem; color: var(--ink-soft); padding: 8px 0 24px; }
  .chip { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.04em;
    text-transform: uppercase; border: 1px solid var(--line-hard); padding: 2px 7px;
    color: var(--ink); }
  .chip.stage { background: var(--ink); color: var(--paper); border-color: var(--ink); }

  .empty { color: var(--ink-soft); font-style: italic; padding: 40px 0; }

  /* Section rule */
  .srule { display: flex; align-items: center; gap: 12px; margin: 34px 0 14px; }
  .srule h2 { font-size: 0.74rem; letter-spacing: 0.16em; text-transform: uppercase;
    margin: 0; font-weight: 700; color: var(--ink-soft); white-space: nowrap; }
  .srule::after { content: ""; flex: 1; height: 1px; background: var(--line-hard); }

  /* Featured pick */
  .pick { border: 1px solid var(--line-hard); background: var(--panel); }
  .pick .head { display: flex; justify-content: space-between; align-items: baseline;
    gap: 12px; flex-wrap: wrap; padding: 14px 18px; border-bottom: 1px solid var(--line); }
  .pick .head h1 { font-size: 1.35rem; margin: 0; letter-spacing: -0.01em; }
  .pick .head .meta { font-family: var(--mono); font-size: 0.72rem; color: var(--ink-soft); }

  /* Stat strip */
  .stats { display: grid; grid-template-columns: repeat(5, 1fr);
    border-bottom: 1px solid var(--line); }
  .stat { padding: 12px 16px; border-left: 1px solid var(--line); }
  .stat:first-child { border-left: 0; }
  .stat .k { font-size: 0.6rem; letter-spacing: 0.13em; text-transform: uppercase;
    color: var(--ink-soft); }
  .stat .v { font-family: var(--mono); font-variant-numeric: tabular-nums;
    font-size: 1.24rem; margin-top: 4px; line-height: 1.1; }
  .stat .v small { font-size: 0.72rem; color: var(--ink-soft); }
  .stat.cap .v { color: var(--signal); }
  @media (max-width: 720px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
    .stat { border-top: 1px solid var(--line); }
  }

  .body2 { display: grid; grid-template-columns: 340px 1fr; gap: 0; }
  @media (max-width: 860px) { .body2 { grid-template-columns: 1fr; } }

  /* Pitch */
  .pitch { background: var(--pitch); padding: 16px 10px; position: relative;
    border-right: 1px solid var(--line); overflow: hidden; }
  @media (max-width: 860px) { .pitch { border-right: 0; border-bottom: 1px solid var(--line); } }
  .pitch::before { content: ""; position: absolute; inset: 10px;
    border: 1px solid var(--pitch-line); pointer-events: none; }
  .pitch::after { content: ""; position: absolute; left: 10px; right: 10px; top: 50%;
    height: 0; border-top: 1px solid var(--pitch-line); pointer-events: none; }
  .line { display: flex; justify-content: center; gap: 8px; flex-wrap: wrap;
    position: relative; z-index: 1; margin: 10px 0; }
  .p {
    background: var(--panel); color: var(--ink); border: 1px solid var(--line-hard);
    min-width: 76px; max-width: 96px; padding: 5px 6px; text-align: center;
  }
  .p .nm { font-size: 0.72rem; font-weight: 600; white-space: nowrap; overflow: hidden;
    text-overflow: ellipsis; }
  .p .sub { font-family: var(--mono); font-size: 0.6rem; color: var(--ink-soft);
    margin-top: 2px; display: flex; justify-content: space-between; gap: 4px; }
  .p .ceil { color: var(--signal); font-weight: 700; }
  .p.captain { border-color: var(--signal); border-width: 2px; padding: 4px 5px; }
  .p .tag { position: relative; }
  .p .tag b { position: absolute; top: -13px; right: -8px; font-family: var(--mono);
    font-size: 0.58rem; background: var(--signal); color: #fff; padding: 0 3px; }
  .p.vice .tag b { background: var(--ink-soft); }

  /* Starters table */
  .tbl-wrap { overflow-x: auto; }
  table { border-collapse: collapse; width: 100%; font-size: 0.82rem; }
  th, td { padding: 6px 12px; text-align: left; border-bottom: 1px solid var(--line);
    white-space: nowrap; }
  thead th { font-size: 0.6rem; letter-spacing: 0.09em; text-transform: uppercase;
    color: var(--ink-soft); font-weight: 700; border-bottom: 1px solid var(--line-hard); }
  td.n, th.n { text-align: right; font-family: var(--mono); font-variant-numeric: tabular-nums; }
  td.ceil { color: var(--signal); font-weight: 700; }
  tr.cap td { background: color-mix(in srgb, var(--signal) 10%, transparent); }
  tr.cap td:first-child { box-shadow: inset 3px 0 0 var(--signal); }
  .role { font-family: var(--mono); font-size: 0.64rem; color: var(--ink-soft);
    text-transform: uppercase; letter-spacing: 0.05em; }
  .otw { color: var(--signal); font-family: var(--mono); font-size: 0.6rem; margin-left: 5px; }
  .flag-out { color: var(--stale); font-family: var(--mono); font-size: 0.6rem; margin-left: 5px; }

  .bench { padding: 10px 12px; border-top: 1px solid var(--line); font-size: 0.78rem; }
  .bench .lbl { font-size: 0.6rem; letter-spacing: 0.13em; text-transform: uppercase;
    color: var(--ink-soft); margin-right: 8px; }
  .bench span.b { font-family: var(--mono); margin-right: 14px; }
  .bench span.b i { font-style: normal; color: var(--ink-soft); }

  .capnote { padding: 10px 18px; border-top: 1px solid var(--line);
    font-size: 0.78rem; color: var(--ink-soft); }
  .capnote b { color: var(--ink); }

  /* Transfers */
  .xfer { padding: 12px 18px; border-top: 1px solid var(--line); font-size: 0.8rem; }
  .xfer .cols { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 6px; }
  .xfer ul { margin: 4px 0 0; padding-left: 16px; }
  .xfer .in b { color: var(--accent); }
  .xfer .out b { color: var(--stale); }

  /* Freshness */
  .fresh-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .fcell { background: var(--panel); padding: 10px 14px; display: flex; align-items: center; gap: 10px; }
  .fcell .fdot { width: 8px; height: 8px; border-radius: 50%; flex: none; }
  .fcell.fresh .fdot { background: var(--fresh); }
  .fcell.warn .fdot { background: var(--warn); }
  .fcell.stale .fdot { background: var(--stale); }
  .fcell.missing .fdot { background: var(--line-hard); }
  .fcell .ft { line-height: 1.25; }
  .fcell .ft .fl { font-size: 0.74rem; }
  .fcell .ft .fa { font-family: var(--mono); font-size: 0.66rem; color: var(--ink-soft); }

  /* History */
  details.hist { border: 1px solid var(--line); background: var(--panel); margin-bottom: 8px; }
  details.hist > summary { cursor: pointer; padding: 8px 14px; font-family: var(--mono);
    font-size: 0.74rem; list-style: none; display: flex; justify-content: space-between; }
  details.hist > summary::-webkit-details-marker { display: none; }
  details.hist[open] > summary { border-bottom: 1px solid var(--line); }
  .hrow { display: grid; grid-template-columns: 1fr auto auto; gap: 12px; align-items: baseline;
    padding: 6px 14px; border-bottom: 1px solid var(--line); font-size: 0.76rem; }
  .hrow:last-child { border-bottom: 0; }
  .hrow .hm { font-family: var(--mono); font-size: 0.68rem; color: var(--ink-soft); }
  .hrow a { color: var(--accent); text-decoration: none; font-family: var(--mono);
    font-size: 0.68rem; }
  .hrow a:hover { text-decoration: underline; }

  footer { margin-top: 40px; padding-top: 14px; border-top: 1px solid var(--line);
    font-family: var(--mono); font-size: 0.68rem; color: var(--ink-soft);
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
</style>
</head>
<body>
<div class="wrap">

  <header class="mast">
    <div class="brand">WC2026 Prediction Desk<small>FIFA Fantasy World Cup 2026</small></div>
    <div class="status">
      {% if featured %}<div>computed {{ featured.generated_at_utc }}</div>{% endif %}
      <div>rendered {{ built_at }}</div>
    </div>
  </header>

  <div class="subline">
    {% if featured %}<span class="chip stage">{{ featured.stage_label }}</span>{% endif %}
    <span>{{ total_recommendations }} runs archived across {{ n_stages }} stages</span>
  </div>

  {% if not featured %}
    <p class="empty">No recommendations yet. Run <span class="num">python -m fifa_fantasy.optimizer</span>.</p>
  {% else %}

  {# ---------------- Featured pick ---------------- #}
  <div class="pick">
    <div class="head">
      <h1>Current pick: {{ featured.stage_label }}</h1>
      <div class="meta">{{ featured.model_backend }}{% if featured.model_version %} {{ featured.model_version }}{% endif %}
        &middot; {{ featured.generated_at_utc }}</div>
    </div>

    <div class="stats">
      <div class="stat">
        <div class="k">Budget</div>
        <div class="v">{{ "%.1f"|format(featured.budget_used) }}<small> / {{ "%.0f"|format(featured.budget_total) }}M</small></div>
      </div>
      <div class="stat">
        <div class="k">Formation</div>
        <div class="v">{{ featured.lineup.formation }}</div>
      </div>
      <div class="stat">
        <div class="k">XI expected</div>
        <div class="v">{{ "%.1f"|format(featured.lineup.expected_points) }}</div>
      </div>
      <div class="stat">
        <div class="k">Horizon expected</div>
        <div class="v">{{ "%.1f"|format(featured.total_horizon_points) }}</div>
      </div>
      {% if f.captain %}
      <div class="stat cap">
        <div class="k">Captain ceiling</div>
        <div class="v">{{ "%.1f"|format(f.captain.predicted_q90 if f.captain.predicted_q90 is not none else f.captain.predicted_points) }}<small> {{ f.captain.last_name }}</small></div>
      </div>
      {% endif %}
    </div>

    <div class="body2">
      {# Pitch #}
      <div class="pitch">
        {% for pos, players in f.pitch_lines %}
          {% if players %}
          <div class="line">
            {% for p in players %}
              <div class="p {% if p.role == 'Captain' %}captain{% elif p.role == 'Vice' %}vice{% endif %}">
                <div class="tag">{% if p.role == 'Captain' %}<b>C</b>{% elif p.role == 'Vice' %}<b>V</b>{% endif %}</div>
                <div class="nm">{{ p.last_name or p.display_name }}</div>
                <div class="sub">
                  <span>{{ p.country_abbr }}</span>
                  <span class="ceil">{{ "%.1f"|format(p.predicted_q90 if p.predicted_q90 is not none else p.predicted_points) }}</span>
                </div>
              </div>
            {% endfor %}
          </div>
          {% endif %}
        {% endfor %}
      </div>

      {# Starters table #}
      <div>
        <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th>Pos</th><th>Player</th><th>Cty</th><th>Fixture</th>
              <th class="n">Price</th><th class="n">Own</th><th class="n">Form</th>
              <th class="n">Floor</th><th class="n">Mean</th><th class="n">Ceiling</th>
            </tr>
          </thead>
          <tbody>
          {% for p in f.starters %}
            <tr class="{% if p.role == 'Captain' %}cap{% endif %}">
              <td class="role">{{ p.position }}{% if p.role == 'Captain' %} C{% elif p.role == 'Vice' %} V{% endif %}</td>
              <td>{{ p.display_name }}{% if p.one_to_watch %}<span class="otw">OTW</span>{% endif %}{% if p.is_eliminated %}<span class="flag-out">OUT</span>{% endif %}</td>
              <td class="num">{{ p.country_abbr }}</td>
              <td class="num">{% if p.is_home %}v {{ p.opponent_abbr }}{% else %}@ {{ p.opponent_abbr }}{% endif %}</td>
              <td class="n">{{ "%.1f"|format(p.price_millions) }}</td>
              <td class="n">{{ "%.0f"|format(p.ownership_fraction * 100) }}%</td>
              <td class="n">{{ "%.1f"|format(p.form) if p.form is not none else "-" }}</td>
              <td class="n">{{ "%.1f"|format(p.predicted_q10) if p.predicted_q10 is not none else "-" }}</td>
              <td class="n">{{ "%.1f"|format(p.predicted_points) }}</td>
              <td class="n ceil">{{ "%.1f"|format(p.predicted_q90) if p.predicted_q90 is not none else "-" }}</td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
        </div>

        <div class="bench">
          <span class="lbl">Bench</span>
          {% for p in f.bench %}
            <span class="b">{{ loop.index }}. {{ p.last_name or p.display_name }} <i>{{ p.country_abbr }} {{ p.position }}</i></span>
          {% else %}
            <span class="b"><i>none</i></span>
          {% endfor %}
        </div>
      </div>
    </div>

    {% if f.captain %}
    <div class="capnote">
      Captaining <b>{{ f.captain.display_name }}</b> ({{ f.captain.country_abbr }}):
      mean {{ "%.1f"|format(f.captain.predicted_points) }}, ceiling
      {{ "%.1f"|format(f.captain.predicted_q90 if f.captain.predicted_q90 is not none else f.captain.predicted_points) }}.
      Chasing rewards the ceiling, so the pick leans on the q90 head, not the average.
      {% if f.vice %}Vice: <b>{{ f.vice.display_name }}</b>.{% endif %}
    </div>
    {% endif %}

    {% if featured.transfer %}
    <div class="xfer">
      <b>Transfers:</b> {{ featured.transfer.n_transfers }} made,
      {{ featured.transfer.n_extra_transfers }} above quota, hit {{ featured.transfer.transfer_cost_points }} pts.
      <div class="cols">
        <div class="in"><b>In</b>
          <ul>
          {% for d in featured.transfer.transfers_in_detail %}
            <li>{{ d.full_name }} <span class="num">({{ d.country_abbr }} {{ d.position }} {{ "%.1f"|format(d.price_millions) }}M)</span></li>
          {% else %}<li>none</li>{% endfor %}
          </ul>
        </div>
        <div class="out"><b>Out</b>
          <ul>
          {% for d in featured.transfer.transfers_out_detail %}
            <li>{% if d.full_name %}{{ d.full_name }} <span class="num">({{ d.country_abbr }} {{ d.position }} {{ "%.1f"|format(d.price_millions) }}M)</span>{% else %}player {{ d.player_id }}{% endif %}</li>
          {% else %}<li>none</li>{% endfor %}
          </ul>
        </div>
      </div>
    </div>
    {% endif %}

    <div class="links" style="padding:10px 18px;border-top:1px solid var(--line);font-family:var(--mono);font-size:0.7rem;">
      <a href="{{ featured.__filename__ }}" style="color:var(--accent);text-decoration:none;margin-right:16px;">json</a>
      <a href="{{ featured.__md_filename__ }}" style="color:var(--accent);text-decoration:none;">markdown</a>
    </div>
  </div>

  {# ---------------- Data freshness ---------------- #}
  <div class="srule"><h2>Data freshness</h2></div>
  <div class="fresh-grid">
    {% for s in freshness %}
    <div class="fcell {{ s.status }}">
      <span class="fdot"></span>
      <div class="ft">
        <div class="fl">{{ s.label }}</div>
        <div class="fa">{{ s.age_str }}{% if s.when %} &middot; {{ s.when }}{% endif %}</div>
      </div>
    </div>
    {% endfor %}
  </div>

  {# ---------------- History ---------------- #}
  {% if history %}
  <div class="srule"><h2>Archive</h2></div>
  {% for group in history %}
  <details class="hist">
    <summary><span>{{ group.stage_label }}</span><span>{{ group['items']|length }} run(s)</span></summary>
    {% for r in group['items'] %}
    <div class="hrow">
      <span>{{ r.model_backend }}{% if r.model_version %} {{ r.model_version }}{% endif %}
        <span class="hm">XI {{ "%.1f"|format(r.lineup.expected_points) }} &middot; {{ "%.1f"|format(r.budget_used) }}M</span></span>
      <span class="hm">{{ r.generated_at_utc }}</span>
      <span><a href="{{ r.__filename__ }}">json</a> <a href="{{ r.__md_filename__ }}">md</a></span>
    </div>
    {% endfor %}
  </details>
  {% endfor %}
  {% endif %}

  {% if live_reports %}
  <div class="srule"><h2>Live reports</h2></div>
  <details class="hist" open>
    <summary><span>match reports</span><span>{{ live_reports|length }}</span></summary>
    {% for lr in live_reports %}
    <div class="hrow"><span><a href="{{ lr.filename }}">{{ lr.filename }}</a></span><span></span><span></span></div>
    {% endfor %}
  </details>
  {% endif %}

  {% endif %}

  <footer>
    <span>Rendered on request from the latest results in results/. Refresh to update.</span>
    <span>Authors: A. D. Lopez, D. Guajardo</span>
  </footer>
</div>
</body>
</html>
