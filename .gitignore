# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# Virtualenv
.venv/

# Collector raw JSON snapshots (always regenerated; never committed)
data/raw/raw/

# Daily Parquet rolls from the pipeline (most are regenerated)
data/raw/*.parquet
data/processed/*.parquet

# Re-include the pre-tournament bundled snapshot so a fresh clone can
# run the optimizer end-to-end without re-scraping or retraining.
!data/raw/players_2026-06-08.parquet
!data/raw/squads_2026-06-08.parquet
!data/raw/fixtures_2026-06-08.parquet
!data/processed/features_2026-06-08.parquet
!data/processed/predictions_2026-06-08.parquet

# Re-include per-matchday API snapshots so the whitepaper's live-results
# section is reproducible. Each entry is a decision-point snapshot.
!data/raw/players_2026-06-18.parquet
!data/raw/squads_2026-06-18.parquet
!data/raw/fixtures_2026-06-18.parquet
!data/raw/players_2026-06-21.parquet
!data/raw/squads_2026-06-21.parquet
!data/raw/fixtures_2026-06-21.parquet
!data/raw/players_2026-06-23.parquet
!data/raw/squads_2026-06-23.parquet
!data/raw/fixtures_2026-06-23.parquet
!data/raw/players_2026-06-24.parquet
!data/raw/squads_2026-06-24.parquet
!data/raw/fixtures_2026-06-24.parquet
!data/raw/players_2026-06-28.parquet
!data/raw/squads_2026-06-28.parquet
!data/raw/fixtures_2026-06-28.parquet
!data/processed/features_2026-06-18.parquet
!data/processed/features_2026-06-21.parquet
!data/processed/features_2026-06-23.parquet
!data/processed/features_2026-06-24.parquet
!data/processed/features_2026-06-28.parquet
!data/processed/predictions_2026-06-18.parquet

# External raw caches (regenerable via `python -m fifa_fantasy.external`)
data/external/cache/
data/external/football_data/

# Generated dashboards (per-run output)
results/*.html

# Editor
.vscode/
.idea/

