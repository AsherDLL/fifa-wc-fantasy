!data/processed/features_2026-06-24.parquet
!data/processed/features_2026-06-28.parquet
!data/processed/predictions_2026-06-18.parquet

# External raw caches (regenerable via `python -m fifa_fantasy.external`)
data/external/cache/
data/external/football_data/

# Generated dashboards (per-run output). The four page snapshots and the
# figure SVGs are re-included so a fresh clone gets a complete dashboard
# without running the pipeline; results/report/ is a regenerable aggregate.
results/*.html
!results/index.html
!results/algorithms.html
!results/intelligence.html
!results/research.html
!results/figures/
results/report/

